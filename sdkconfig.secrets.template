
вщт# Picture Weather Station — secrets & per-installation settings
# Copy this file to `sdkconfig.secrets` and fill in your values.
# sdkconfig.secrets is gitignored and never committed.
#
# All options below are also available via `idf.py menuconfig`
# under "Picture Weather Station".

# -----------------------------------------------------------------------
# WiFi (required)
# -----------------------------------------------------------------------
CONFIG_PWS_WIFI_SSID="YourSSID"
CONFIG_PWS_WIFI_PASSWORD="YourPassword"

# -----------------------------------------------------------------------
# Location (for Open-Meteo weather forecast)
# Decimal degrees, e.g. "60.1699" / "24.9384"
# -----------------------------------------------------------------------
CONFIG_PWS_LAT="60.25"
CONFIG_PWS_LON="20.27"

# -----------------------------------------------------------------------
# Ruuvi Tag
# Last 2 bytes of the tag's MAC address as a 4-hex-digit value,
# e.g. 0xE524.
# -----------------------------------------------------------------------
CONFIG_PWS_RUUVI_SIGNATURE=0x0000

# -----------------------------------------------------------------------
# Adafruit IO  (https://io.adafruit.com)
# Leave empty to disable Adafruit IO integration.
# -----------------------------------------------------------------------

# Your Adafruit IO username
CONFIG_PWS_ADAFRUIT_IO_USER=""

# Active Key from io.adafruit.com -> My Key
CONFIG_PWS_ADAFRUIT_IO_KEY=""

# Feed key to READ a single latest value from (shown in the "AdaIO" widget)
CONFIG_PWS_ADAFRUIT_IO_CO2_FEED_KEY=""

# Feed key to READ a single latest value from (shown in the "AdaIO" widget)
CONFIG_PWS_ADAFRUIT_IO_TEMPERATURE_FEED_KEY=""

# Feed key to READ a single latest value from (shown in the "AdaIO" widget)
CONFIG_PWS_ADAFRUIT_IO_HUMIDITY_FEED_KEY=""

# Feed key to PUBLISH Ruuvi sensor data to (JSON: temperature, pressure, humidity)
CONFIG_PWS_ADAFRUIT_IO_PUBLISH_JSON_FEED=""

# Feed key to PUBLISH barometric pressure (mmHg) to.
# Leave empty to disable pressure publishing.
CONFIG_PWS_ADAFRUIT_IO_PRESSURE_FEED_KEY=""
