import { HorizontalBox } from "std-widgets.slint";
import { DataWidget } from "./data-widget.slint";
import { WeatherIcon } from "./weather-icon.slint";
import { Chart, ChartSupport } from "./chart.slint";
export { ChartSupport }
export enum FoxConditionEnum { wind, rain, snow, sun }

export struct RuuviData {
    tempC: float,
    atmPHgmm: float,
    relHumidity: float,
    connFail: bool,
    battV: float}


export struct OpenMeteoData {
    tempC: float,
    tempFeelsC: float,
    windSpeed: float,
    windGusts: float,
    windDir: string,
    condition: FoxConditionEnum,
    connFail: bool}

export struct AdaIoData {
    value: float,
    connFail: bool}

export struct LocalData {
    tempC: float,
    relHumidity: float,
    tempHistory: [float]
}

export component WeatherStation inherits Window {
    in property <int> weather-code: -1;
    in property <bool> day: true;
    in property <LocalData> indoor-data: { relHumidity:0.0001, tempC:-10.00001 };
    in property <AdaIoData> adafruit-data: { value: 333.33455453, connFail: true };
    in property <RuuviData> roovi-data: { relHumidity: 0.0001, tempC: 0.0001, atmPHgmm: 0.0001, battV: 2.7, connFail: true };
    in property <[float]> chart-history;
    in property <OpenMeteoData> meteo-data: {
        tempC: -15.6777,
        tempFeelsC: -18.788878,
        windSpeed: 5.47474,
        windGusts: 7.211,
        windDir: "NW",
        connFail: true
    };
    private property <physical-length> main-font-size:13px;
    private property <physical-length> reg-widget-width:73px;

    width: 800px;
    height: 480px;
    background: #FF7F00;
    WeatherIcon {
        x: 0;
        y: 0px;
        day: day;
        code: weather-code;
    }

    DataWidget {
        name: "AdaIO";
        valid: !adafruit-data.connFail;
        x: 79px;
        y: 7px;
        width: 83px;
        HorizontalLayout {
            x: 4px;
            alignment: start;
            Text {
                text: "CO";
                color: white;
                font-size: main-font-size;
            }

            Text {
                y: 3px;
                color: white;
                font-size: main-font-size - 2px;
                text: "2";
            }

            Text {
                text: ": \{ adafruit-data.value.to-fixed(0)}";
                width: 32px;
                color: white;
                font-size: main-font-size;
            }
        }

        Text {
            horizontal-alignment: center;
            text: "ppm";
            color: white;
            font-size: main-font-size;
        }
    }

    DataWidget {
        name: "Ruuvi";
        x: 7px;
        y: 184px;
        valid: !roovi-data.connFail;
        GridLayout {
        	width: 133px;
            spacing-horizontal: 8px;
            Row {
                HorizontalLayout {
                    alignment: start;
                    Text {
                        color: white;
                        font-size: main-font-size;
                        text: "T: \{roovi-data.tempC.to-fixed(1)}";
                    }

                    Text {
                        color: white;
                        font-size: 8px;
                        text: "O";
                    }

                    Text {
                        color: white;
                        font-size: main-font-size;
                        text: "C";
                    }
                }

                Text {
                    color: white;
                    font-size: main-font-size;
                    text: "H: \{roovi-data.relHumidity.to-fixed(0)}%";
                }
            }

            Row {
                Text {
                    color: white;
                    font-size: main-font-size;
                    text: "P: \{roovi-data.atmPHgmm.to-fixed(0)} mmHg";
                }

                Text {
                    color: roovi-data.battV > 2.7 ? white : roovi-data.battV > 2.5 ? yellow : darkred;
                    font-size: main-font-size;
                    text: "Bat: \{roovi-data.battV.to-fixed(1)}V";
                }
            }
        }
    }

    DataWidget {
        name: "City";
        x: 1px;
        y: 1px;
        valid: !meteo-data.connFail;
        HorizontalLayout {
        	width: 133px;
            alignment: start;
            Text {
                color: white;
                font-size: main-font-size;
                text: "T: \{meteo-data.tempC.to-fixed(1)} (\{meteo-data.tempFeelsC.to-fixed(1)} )";
            }

            Text {
                color: white;
                font-size: 8px;
                text: "O";
            }

            Text {
                color: white;
                font-size: main-font-size;
                text: "C";
            }
        }

        Text {
            color: white;
            font-size: main-font-size;
            text: "Wind: \{meteo-data.windDir} \{meteo-data.windSpeed.to-fixed(1)} (\{meteo-data.windGusts.to-fixed(0)}) m/s";
        }
    }

    DataWidget {
        name: "Local";
        x: 1px;
        y: 1px;
        HorizontalLayout {
        	width: 1px;
            spacing: 1px;
            HorizontalLayout {
                alignment: start;
                Text {
                    color: white;
                    font-size: main-font-size;
                    text: "T: \{indoor-data.tempC.to-fixed(1)}";
                }

                Text {
                    color: white;
                    font-size: 8px;
                    text: "O";
                }

                Text {
                    color: white;
                    font-size: main-font-size;
                    text: "C";
                }
            }

            Text {
                color: white;
                font-size: main-font-size;
                text: "H: \{indoor-data.relHumidity.to-fixed(0)}%";
            }
        }
    }

    Image {
    	x:0;
    	y:0;
        source: @image-url("../pict/pencifox/ready/cloudy.png");
    }
    Image {
    	x: 250px;
    	y:0;
        source: @image-url("../pict/pencifox/ready/foggy.png");
    }
    Image {
    	x: 500px;
    	y:0;
        source: @image-url("../pict/pencifox/ready/rainy.png");
    }

    Image {
    	x:0;
    	y:250px;
        source: @image-url("../pict/pencifox/ready/snowy.png");
    }
    Image {
    	x: 250px;
    	y:250px;
        source: @image-url("../pict/pencifox/ready/sunny.png");
    }
    Image {
    	x: 500px;
    	y:250px;
        source: @image-url("../pict/pencifox/ready/windy.png");
    }

    Chart {
        x: 750px;
        y: 162px;
        width: 50px;
        height: 78px;
        background: blue;
        data: chart-history;
    }
}
