import { HorizontalBox } from "std-widgets.slint";
import { DataWidget } from "./data-widget.slint";
import { WeatherIcon } from "./weather-icon.slint";
import { Chart, ChartSupport } from "./chart.slint";
export { ChartSupport }
export enum FoxConditionEnum { wind, rain, snow, sun }

export struct RuuviData {
    tempC: float,
    atmPHgmm: float,
    relHumidity: float,
    connFail: bool,
    battV: float}


export struct OpenMeteoData {
    tempC: float,
    tempFeelsC: float,
    windSpeed: float,
    windGusts: float,
    windDir: string,
    condition: FoxConditionEnum,
    connFail: bool}

export struct AdaIoData {
    value: float,
    connFail: bool}

export struct LocalData {
    tempC: float,
    relHumidity: float,
    tempHistory: [float]
}

export component WeatherStation inherits Window {
    in property <int> weather-code: -1;
    in property <bool> day: true;
    in property <LocalData> indoor-data: { relHumidity:0.0001, tempC:-10.00001 };
    in property <AdaIoData> adafruit-data: { value: 33.33455453, connFail: true };
    in property <RuuviData> roovi-data: { relHumidity: 0.0001, tempC: 0.0001, atmPHgmm: 0.0001, battV: 2.7, connFail: true };
    in property <OpenMeteoData> meteo-data: {
        tempC: -15.6777,
        tempFeelsC: -18.788878,
        windSpeed: 5.47474,
        windGusts: 7.211,
        windDir: "NW",
        connFail: true
    };

    width: 240px;
    height: 320px;
    background: #FF7F00;

    DataWidget {
        name: "Ruuvi";
        x: 7px;
        y: 265px;
        valid: !roovi-data.connFail;
        GridLayout {
            spacing-horizontal: 8px;
            Row {
                HorizontalLayout {
                    alignment: start;
                    Text {
                        color: white;
                        font-size: 14px;
                        text: "T: \{roovi-data.tempC.to-fixed(1)}";
                    }

                    Text {
                        color: white;
                        font-size: 8px;
                        text: "O";
                    }

                    Text {
                        color: white;
                        font-size: 14px;
                        text: "C";
                    }
                }

                Text {
                    color: white;
                    font-size: 14px;
                    text: "H: \{roovi-data.relHumidity.to-fixed(0)}%";
                }
            }

            Row {
                Text {
                    color: white;
                    font-size: 14px;
                    text: "P: \{roovi-data.atmPHgmm.to-fixed(0)} mmHg";
                }

                Text {
                    color: roovi-data.battV > 2.7 ? white : roovi-data.battV > 2.5 ? yellow : darkred;
                    font-size: 14px;
                    text: "Bat: \{roovi-data.battV.to-fixed(1)}V";
                }
            }
        }
    }

    DataWidget {
        name: "City";
        x: 7px;
        y: 170px;
        valid: !meteo-data.connFail;
        HorizontalLayout {
            alignment: start;
            Text {
                color: white;
                font-size: 14px;
                text: "T: \{meteo-data.tempC.to-fixed(1)} (\{meteo-data.tempFeelsC.to-fixed(1)} )";
            }

            Text {
                color: white;
                font-size: 8px;
                text: "O";
            }

            Text {
                color: white;
                font-size: 14px;
                text: "C";
            }
        }

        Text {
            color: white;
            font-size: 14px;
            text: "Wind: \{meteo-data.windDir} \{meteo-data.windSpeed.to-fixed(1)} (\{meteo-data.windGusts.to-fixed(0)}) m/s";
        }
    }

    DataWidget {
        name: "Local";
        x: 7px;
        y: 227px;
        HorizontalLayout {
            spacing: 8px;
            HorizontalLayout {
                alignment: start;
                Text {
                    color: white;
                    font-size: 14px;
                    text: "T: \{indoor-data.tempC.to-fixed(1)}";
                }

                Text {
                    color: white;
                    font-size: 8px;
                    text: "O";
                }

                Text {
                    color: white;
                    font-size: 14px;
                    text: "C";
                }
            }

            Text {
                color: white;
                font-size: 14px;
                text: "H: \{indoor-data.relHumidity.to-fixed(0)}%";
            }
        }
    }

    Image {
        x: parent.width - self.width;
        y: 0;
        source: meteo-data.condition == FoxConditionEnum.wind ? @image-url("../pict/fox_wind.png") : meteo-data.condition == FoxConditionEnum.snow ? @image-url("../pict/fox_snow.png") : meteo-data.condition == FoxConditionEnum.rain ? @image-url("../pict/fox_rain.png") : @image-url("../pict/fox_sun.png");
    }

    WeatherIcon {
        x: 0;
        y: 80px;
        day: day;
        code: weather-code;
    }

    DataWidget {
        name: "AdaIO";
        valid: !adafruit-data.connFail;
        x: 140px;
        y: 227px;
        HorizontalLayout {
            x: 4px;
            alignment: start;
            Text {
                text: "CO";
                color: white;
                font-size: 14px;
            }

            Text {
                y: 5px;
                color: white;
                font-size: 12px;
                text: "2";
            }

            Text {
                text: ": \{ adafruit-data.value.to-fixed(0)}ppm";
                color: white;
                font-size: 14px;
            }
        }
    }
    Chart {
    	x:100px;
    	y:100px;
    	width: 140px;
    	height: 100px;
    	background: blue;
    	data: indoor-data.tempHistory;
    }
}
