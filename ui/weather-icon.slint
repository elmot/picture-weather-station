 code == 03? @image-url("../pict/svg_png/cloudy.png") :
 code == 45? @image-url("../pict/svg_png/fog.png") :
 code == 48? @image-url("../pict/svg_png/fog.png") :
 code == 51? ( day? @image-url("../pict/svg_png/lightrainshowers_day.png") :  @image-url("../pict/svg_png/lightrainshowers_night.png")) :
 code == 53? ( day? @image-url("../pict/svg_png/rainshowers_day.png") :  @image-url("../pict/svg_png/rainshowers_night.png")) :
