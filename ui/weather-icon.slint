 code == 57? ( day? @image-url("../pict/svg_png/sleetshowers_day.png") :  @image-url("../pict/svg_png/sleetshowers_night.png")) :
 code == 61? ( day? @image-url("../pict/svg_png/lightrainshowers_day.png") :  @image-url("../pict/svg_png/lightrainshowers_night.png")) :
 code == 63? ( day? @image-url("../pict/svg_png/rainshowers_day.png") :  @image-url("../pict/svg_png/rainshowers_night.png")) :
 code == 65? ( day? @image-url("../pict/svg_png/heavyrainshowers_day.png") :  @image-url("../pict/svg_png/heavyrainshowers_night.png")) :
 code == 66? ( day? @image-url("../pict/svg_png/lightsleetshowers_day.png") :  @image-url("../pict/svg_png/lightsleetshowers_night.png")) :
 code == 67? ( day? @image-url("../pict/svg_png/sleetshowers_day.png") :  @image-url("../pict/svg_png/sleetshowers_night.png")) :
 code == 71? ( day? @image-url("../pict/svg_png/lightsnowshowers_day.png") :  @image-url("../pict/svg_png/lightsnowshowers_night.png")) :
 code == 73? ( day? @image-url("../pict/svg_png/snowshowers_day.png") :  @image-url("../pict/svg_png/snowshowers_night.png")) :
 code == 75? ( day? @image-url("../pict/svg_png/heavysnowshowers_day.png") :  @image-url("../pict/svg_png/heavysnowshowers_night.png")) :
 code == 77? ( day? @image-url("../pict/svg_png/heavysnowshowers_day.png") :  @image-url("../pict/svg_png/heavysnowshowers_night.png")) :
 code == 80? ( day? @image-url("../pict/svg_png/lightrainshowers_day.png") :  @image-url("../pict/svg_png/lightrainshowers_night.png")) :
 code == 81? ( day? @image-url("../pict/svg_png/rainshowers_day.png") :  @image-url("../pict/svg_png/rainshowers_night.png")) :
