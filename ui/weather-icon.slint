export component WeatherIcon inherits Image {
    in property <int> code: -1;
    in property <bool> day: false;
    source:
 code == 00? ( day? @image-url("../pict/svg_png/clearsky_day.png") :  @image-url("../pict/svg_png/clearsky_night.png")) :
 code == 01? ( day? @image-url("../pict/svg_png/fair_day.png") :  @image-url("../pict/svg_png/fair_night.png")) :
